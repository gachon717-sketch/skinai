# 이 파일을 복사해 .streamlit/secrets.toml 로 저장하거나,
# Streamlit Cloud 배포 시 App settings > Secrets 에 아래 내용을 붙여넣으세요.
# secrets.toml 실제 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함되어 있음).

# ── AI 인증 (둘 중 하나만 있으면 됨, 둘 다 있으면 VERTEX_PROJECT 우선) ──

# 방식 1: Vertex AI — Google Cloud 프로젝트 크레딧 사용.
# 컴퓨터에 gcloud 로그인(gcloud auth application-default login)이 되어 있어야 동작.
# 로컬(병원 PC) 실행에 적합. Streamlit Cloud에서는 사용 불가(서비스 계정 필요).
VERTEX_PROJECT = ""
VERTEX_LOCATION = "us-central1"

# 방식 2: API 키 — Google AI Studio에서 발급 (https://aistudio.google.com/apikey)
# "AIza..." 로 시작하는 39자 문자열. Streamlit Cloud 배포 시에는 이 방식 필요.
GEMINI_API_KEY = ""

# 선택: 사용할 모델 (기본값 gemini-2.5-pro)
GEMINI_MODEL = "gemini-2.5-pro"

# 접속 비밀번호를 2주 주기로 자동 생성하는 데 쓰이는 비밀 시드 값.
# 길고 무작위한 문자열로 직접 정하고, 외부에 노출되지 않게 하세요.
PASSWORD_SECRET = "change-this-to-a-long-random-string"

# 사이드바 관리자 패널(현재/다음 비밀번호 확인)에 접근하기 위한 별도 코드.
ADMIN_KEY = "choose-a-separate-admin-code"

# ── 모드 (선택) ──
# "clinic"  = 병원 내 QR용 (기본값, 비밀번호 필요 + 네이버 리뷰 동선)
# "external" = SNS 공개용 (비밀번호 없음 + 카카오 상담 동선 + 이름 안 받음 + 일일 상한)
# 이 줄을 아예 넣지 않으면 무조건 clinic 으로 동작 (병원용 앱은 건드릴 필요 없음).
MODE = "clinic"

# 외부(external) 모드에서 하루 최대 분석 횟수 (비용 방어). 기본값 200.
DAILY_LIMIT = "200"

# ── 구글 시트 데이터 축적 (선택) ──
# 아래 두 가지가 모두 있으면 분석/클릭 데이터가 익명으로 구글 시트에 자동 기록됨.
# 없으면 조용히 스킵 (앱 동작에는 영향 없음).
# GSHEET_ID = "구글 시트 URL 가운데의 긴 문자열"
# [gcp_service_account]  # 구글 서비스 계정 JSON 키의 내용을 여기에 TOML로 붙여넣기
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# client_id = "..."
# token_uri = "https://oauth2.googleapis.com/token"
